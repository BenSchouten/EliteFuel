# Local PostgreSQL example. For Vercel/hosted Postgres, use the provider's pooled Prisma connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/elitefuel?schema=public"
NEXTAUTH_SECRET="replace-with-a-local-secret"
# Local development URL. In Vercel, set this to your deployed https:// URL.
NEXTAUTH_URL="http://localhost:3000"

# Optional AI support. Leave blank for safe local fallback behavior.
OPENAI_API_KEY=""
OPENAI_TEXT_MODEL="gpt-4.1-mini"
OPENAI_VISION_MODEL="gpt-4.1-mini"
